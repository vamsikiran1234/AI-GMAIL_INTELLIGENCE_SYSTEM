# Backend
SERVER_PORT=8080
# Supabase PostgreSQL connection values
# Use the JDBC connection string from Supabase Project Settings > Database > Connection string
DATABASE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-supabase-database-password
GMAIL_OAUTH_CLIENT_ID=your-google-client-id
GMAIL_OAUTH_CLIENT_SECRET=your-google-client-secret
GMAIL_OAUTH_REDIRECT_URI=http://localhost:8080/api/oauth/google/callback
TOKEN_ENCRYPTION_KEY_BASE64=base64-encoded-32-byte-aes-key
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro
NIM_API_KEY=your-nvidia-nim-api-key
NIM_MODEL=meta/llama-3.1-70b-instruct
FRONTEND_ORIGIN=http://localhost:5173

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api
