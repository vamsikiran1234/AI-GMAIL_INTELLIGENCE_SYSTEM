# ─── Backend ──────────────────────────────────────────────────────────────────

# Port the Spring Boot API listens on
# Note: port 8080 is often occupied by Oracle TNS Listener on Windows — use 8081
SERVER_PORT=8081

# ─── Supabase PostgreSQL ───────────────────────────────────────────────────────

# JDBC connection string — use the Session Pooler URL from Supabase dashboard
# Project Settings → Database → Connect → Session pooler → JDBC
DATABASE_URL=jdbc:postgresql://aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres?sslmode=require

# Pooler username format: postgres.<project-ref>
DATABASE_USERNAME=postgres.your-project-ref

# Your Supabase database password
DATABASE_PASSWORD=your-supabase-password

# ─── Gmail OAuth 2.0 ──────────────────────────────────────────────────────────

# From Google Cloud Console → APIs & Credentials → OAuth 2.0 Client IDs
GMAIL_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GMAIL_OAUTH_CLIENT_SECRET=GOCSPX-your-client-secret

# Must match exactly what is registered in Google Cloud Console
# Local:      http://localhost:8081/api/oauth/google/callback
# Production: https://your-backend.onrender.com/api/oauth/google/callback
GMAIL_OAUTH_REDIRECT_URI=http://localhost:8081/api/oauth/google/callback

# ─── Token encryption ─────────────────────────────────────────────────────────

# AES-256 key used to encrypt OAuth refresh tokens at rest in the database
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY_BASE64=your-base64-encoded-32-byte-key

# ─── AI Models ────────────────────────────────────────────────────────────────

# Google Gemini — primary model for summarization, drafting, chat, embeddings
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-pro

# NVIDIA NIM — fallback model (free tier available)
# Get key at: https://build.nvidia.com/
NIM_API_KEY=nvapi-your-nim-api-key
NIM_MODEL=meta/llama-3.1-70b-instruct

# ─── CORS ─────────────────────────────────────────────────────────────────────

# Frontend origin the API allows requests from
FRONTEND_ORIGIN=http://localhost:5173

# ─── N8N Internal Webhook Secret ──────────────────────────────────────────────
# Shared secret between N8N and Spring Boot for internal sync webhook
# Generate: openssl rand -hex 32
N8N_INTERNAL_SECRET=your-random-secret-here

# ─── Frontend ─────────────────────────────────────────────────────────────────

# Backend API base URL used by the React app
VITE_API_BASE_URL=http://localhost:8081/api
